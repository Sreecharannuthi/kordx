    android:tint="?attr/colorControlNormal"
    android:autoMirrored="true">
    <!--
       — repeat (off state).
      `autoMirrored="true"` so the arrows flip correctly for RTL.
      The two arrows point in opposite directions (top arrow →, bottom
      arrow ←) for the standard "repeat" semantic; in RTL they auto-flip
      so the icon reads "←" / "→" (the arrows still point in opposite
      directions, but the icon is mirrored so the semantic stays the
      same: "this thing repeats").
