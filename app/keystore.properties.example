# KordX release signing config (TEMPLATE ŌĆö copy and fill in).
#
# 1. Copy this file to `app/keystore.properties` and edit the values.
# 2. `app/keystore.properties` is covered by `.gitignore` ŌĆö never
#    commit the real values.
#
# For the public v1.1.0 release, the keystore + passwords live as
# GitHub Secrets on the Sreecharannuthi/kordx repo. The release
# workflow (.github/workflows/release.yml) decodes them at build
# time and writes a transient `app/keystore.properties` into the
# ephemeral runner. See docs/RELEASING.md for the maintainer runbook.

# Path to the .jks or .keystore file, relative to the repo root.
storeFile=keystore/kordx-release.jks

# Password for the keystore itself (set at keytool generation time).
storePassword=YOUR_KEYSTORE_PASSWORD

# Alias of the signing key inside the keystore.
keyAlias=YOUR_KEY_ALIAS

# Password for the signing key (often the same as the keystore password,
# but keytool allows them to differ).
keyPassword=YOUR_KEY_PASSWORD
