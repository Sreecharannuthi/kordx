<?xml version="1.0" encoding="UTF-8"?>
<!--
  Lint configuration override.

  The `MissingMediaBrowserServiceIntentFilter` check is a static
  check that looks for a service extending
  `android.service.media.MediaBrowserService` with an intent-filter
  for the `android.media.browse.MediaBrowserService` action. The
  active service is the AndroidX Media3 `MediaLibraryService`
  (subclassed by `KordXMediaLibraryService`), not the framework
  `MediaBrowserService` (the framework class was removed in API 35).
  The Media3 `MediaLibraryService` is the modern equivalent; the lint
  check doesn't know about the Media3 class hierarchy, so it surfaces
  a false positive. We disable it for the whole app rather than
  per-element (the `tools:ignore` on the service element doesn't work
  because the check fires on the `<application>` element, not the
  service element).
-->
<lint>
    <issue id="MissingMediaBrowserServiceIntentFilter" severity="ignore" />
</lint>
